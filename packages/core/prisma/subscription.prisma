model Subscription {
    id Int @id @default(autoincrement())

    stripeProductId String? @unique

    name             String
    description      String
    shortDescription String

    color1 String
    color2 String

    // these are all stripe price IDs
    monthlyPriceId  String? @unique
    yearlyPriceId   String? @unique

    lifetimePrice Float?

    imageId Int?

    groupId Int?

    rewards Reward[]

    // THIS IS EXTREMELY IMPORTANT FOR UPGRADING / DOWNGRADING, PLEASE MAKE SURE IT IS HIGHER PRIORITY FOR MORE VALUABLE SUBSCRIPTIONS
    priority Int @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    image Resource? @relation(fields: [imageId], references: [id], onDelete: SetNull)
    group Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)

    userSubscriptions UserSubscription[]
}
